{
  "name": "CareLink - Missed Medication",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "minutes", "minutesInterval": 5 }] }
      },
      "name": "Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.CARELINK_APP_URL}}/api/n8n/alert",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-n8n-secret", "value": "={{$env.N8N_WEBHOOK_SECRET}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"elderId\":\"00000000-0000-4000-8000-000000000001\",\"type\":\"missed_medication\",\"severity\":\"medium\",\"message\":\"Don Manuel no ha confirmado su medicamento de la mañana.\"}"
      },
      "name": "Create Alert",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 300]
    }
  ],
  "connections": {
    "Schedule": { "main": [[{ "node": "Create Alert", "type": "main", "index": 0 }]] }
  }
}
